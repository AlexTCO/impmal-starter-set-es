    "Inquisition Personae - Distinguishing Feature": {
      "name": "Inquisition Personae - Distinguishing Feature",
      "description": "<p>Distinguishing Feature</p>",
      "results": {
        "1-1": "Wears Cadian armour denoting high rank.",
        "2-2": "Their attire is a mix of noble, pious, and military.",
        "3-3": "Half their head has been replaced with metal, both eyes are augmetic.",
        "4-4": "Carries an ancient and elaborate blade weapon that radiates power.",
        "5-5": "A large Inquisitorial tattoo down the back of their shaved head.",
        "6-6": "A mighty two-handed hammer strapped to their back, covered in litanies.",
        "7-7": "Intense eyes, like their gaze can quantify the purity of your soul.",
        "8-8": "They wear very faded Tech-Priest robes under Ministorum armour.",
        "9-9": "Their hood conceals their face except for a single glowing augmetic eye.",
        "10-10": "Wears pieces of ancient Power Armour embellished with images of Saint Macharius."
      }
    },
    "Adeptus Mechanicus Personae - Mannerism": {
      "name": "Adeptus Mechanicus Personae - Mannerism",
      "description": "<p>Mannerism</p>",
      "results": {
        "1-1": "One of their augmetics constantly twitches, out of their control.",
        "2-2": "They emit a long, static sigh before they begin talking.",
        "3-3": "Malfunctioning vox emits  intermittent static clicks.",
        "4-4": "They tap their chin when they are deep in thought.",
        "5-5": "Something in their head whirrs and ticks when they pause their speech.",
        "6-6": "They like to run their fingers over nearby buttons and controls.",
        "7-7": "Forever checking their robes to make sure they’re clean.",
        "8-8": "They often disassociate, their thoughts lost in torrents of data.",
        "9-9": "They absently flick switches and dials on their body, as if they itch.",
        "10-10": "They keep their arms crossed, using only their mechadendrites to interact with the world."
      }
    },
    "Imperium Tech Descriptors": {
      "name": "Imperium Tech Descriptors",
      "description": "<p>Imperium Tech Descriptors</p>",
      "results": {
        "1-5": "A cluster of small antennae purring with static.",
        "6-10": "A skull implanted with glowing red eyes, blinking at you.",
        "11-15": "Frayed cables of various colours, wrapped around its exterior.",
        "16-20": "A row of black and white ivory keys, engraved in High Gothic.",
        "21-25": "Intricate clockwork, with cogs just the width of a hair.",
        "26-30": "Capped pipes which vent a puff of steam at regular intervals.",
        "31-35": "Covered in Mechanicus serial numbers and iconography.",
        "36-40": "A burnished metal skull, a vox-caster in its open mouth.",
        "41-45": "An ornate hand-crank of iron and human bone.",
        "46-50": "A hololithic display upon which scrolls a prayer to the Machine God.",
        "51-55": "Stuck with an undetonated Bolter Round; warnings forbid removal.",
        "56-60": "A grinning skull acts as a control panel, each tooth a button.",
        "61-65": "An archaic tubular speaking horn of tarnished copper.",
        "66-70": "An input keyboard with human knuckle bones for keys.",
        "71-75": "A relief showing local star constellations.",
        "76-80": "A power indicator encased in an iron mesh.",
        "81-85": "A mechadendrite that appears to have no immediate function.",
        "86-90": "Adorned with a trio of red waxed  purity seals.",
        "91-95": "Vacuum tubes containing green gasses.",
        "96-100": "A hololithic display streaming lingua-technis code."
      }
    },
