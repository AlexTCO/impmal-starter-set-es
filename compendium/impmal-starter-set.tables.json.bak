    "Adeptus Mechanicus Personae - Attitude": {
      "name": "Adeptus Mechanicus Personae - Attitude",
      "description": "<p>Attitude</p>",
      "results": {
        "1-1": "Always in a foul mood, but never explains why.",
        "2-2": "Generally content and eager to talk to anyone.",
