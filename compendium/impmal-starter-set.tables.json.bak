    "Administratum Personae - Mannerism": {
      "name": "Administratum Personae - Mannerism",
      "description": "<p>Mannerism</p>",
      "results": {
        "1-1": "Speaks with a pronounced stutter.",
        "2-2": "Laughs at private jokes that only make sense to them.",
        "3-3": "Records every conversation they have via autoquill.",
        "4-4": "Voice becomes robotic when citing regulations stored in their neural augmetics.",
        "5-5": "Speaks to paperwork as if it were more alive than the people who wrote it.",
        "6-6": "Punctuates each of their sentences by knocking on their desk.",
        "7-7": "Hard of hearing, constantly asks others to repeat themselves.",
        "8-8": "Argues bitterly with an inanimate servitor, between bouts of conversation.",
        "9-9": "Whispers to a Servo-Skull who collates their words and repeats them clearly.",
        "10-10": "Vents in their cranial implants vent steam when they are angry or excited."
      }
    },
    "Inquisition Personae - Attitude": {
      "name": "Inquisition Personae - Attitude",
      "description": "<p>Attitude</p>",
      "results": {
        "1-1": "Utterly devoid of humour, as if it was burned out of them.",
        "2-2": "Stern but fair, beloved by their subordinates.",
        "3-3": "Unusually reasonable, willing to hear unorthodox requests or arguments.",
        "4-4": "Knowledgeable about xenos, favours characters who have experience fighting them.",
        "5-5": "Emotionally distant; knows no-one will survive long enough to warrant attachment.",
        "6-6": "They are attentive and helpful to a deliberately unsettling degree.",
        "7-7": "Puritanical through and through, won’t tolerate any disrespect to the Emperor.",
        "8-8": "Is brutally honest about the dangers facing the sector and characters’ chances.",
        "9-9": "Often gets carried away on tangential, obscure details until urged to refocus.",
        "10-10": "Uses a book of Inquisitorial creed to justify their actions, having totally memorised every word within."
      }
    },
    "Rogue Trader Dynasty Personae - Mannerism": {
      "name": "Rogue Trader Dynasty Personae - Mannerism",
      "description": "<p>Mannerism</p>",
      "results": {
        "1-1": "Constantly twirling their moustache or hair.",
        "2-2": "Claps their hands together to emphasise a point.",
        "3-3": "Rubs a charm on a necklace when thinking.",
        "4-4": "Rolls a very large denomination coin across their knuckles.",
        "5-5": "Looks over their shoulder before speaking, as if expecting an ambush.",
        "6-6": "Never without an extravagant goblet of fine spirits in their grasp.",
        "7-7": "Constantly consulting a multitude of scrolls, maps, notes, and books.",
        "8-8": "Constantly smiling as if they already know what a character will say.",
        "9-9": "Makes a show of flipping a coin whenever they are making a decision.",
        "10-10": "Regularly holds a scented handkerchief to their face, as if offended by the stench of those around them."
      }
    },
