    "Imperium Gothic Descriptors": {
      "name": "Imperium Gothic Descriptors",
      "description": "<p>Imperium Gothic Descriptors</p>",
      "results": {
        "1-5": "A pristine skull covered in miniscule etchings of benedictions.",
        "6-10": "A throng of candles, half neatly burnt out.",
        "11-15": "Hanging reams of litany written on lengths of vellum.",
        "16-20": "A vaulted enshrinement of a winged brass skull.",
        "21-25": "An intricate mosaic depicting one of Saint Macharius’ many victories.",
        "26-30": "A relief of Sanguinius, The Emperor’s Angel.",
        "31-35": "A multi-panel fresco relating the early days of the Great Crusade.",
        "36-40": "An altar of black marble, inlaid with golden skulls.",
        "41-45": "A stained glass panel in the form of winged Astartes.",
        "46-50": "Carvings depicting the God-Emperor as Father, Warrior, and Protector.",
        "51-55": "A tapestry depicting the life of a minor Imperial Saint.",
        "56-60": "An illuminated manuscript of High Gothic.",
        "61-65": "Iron effigies of hooded figures, each holding a human bone.",
        "66-70": "A thurible hangs, swinging and spewing heady incense.",
        "71-75": "A relief showing local star constellations.",
        "76-80": "A shield displaying a golden eagle head and wing.",
        "81-85": "An Imperial Aquila cast in dark, hard steel, bearing battle scars.",
        "86-90": "An ornate reliquary, covered in gold and jewels, contents long gone.",
        "91-95": "Punishments for heresy written out on lengths of parchment.",
        "96-100": "Stone hewn statuettes of Cherubim."
      }
    },
    "Commissar’s Inspection": {
      "name": "Commissar’s Inspection",
      "description": "<p>Commissar’s Inspection</p>",
      "results": {
        "1-5": "“Your boots are tied in an unregulated manner.”",
        "6-10": "“There’s dirt on the barrel of your weapon.”",
        "11-15": "“There’s a stain on your trousers.”",
        "16-20": "“The sights of your weapon are mis-aligned.\"",
        "21-25": "“There’s dirt under your fingernails.”",
        "26-30": "“You have a coward’s eyes.”",
        "31-35": "“Your helmet strap is loose.”",
        "36-40": "“Your Uplifting Primer is bent at the corner.”",
        "41-45": "“Your mess kit is improperly packed.”",
        "46-50": "“Your Munitorum-issue knife has a notch in it.”",
        "51-55": "“Your breath smells like a sick grox.”",
        "56-60": "“There is a wrinkle in your collar.”",
        "61-65": "“There is a non-regulation prayer attached to your weapon.”",
        "66-70": "“Your stance is as wide as a Sentinel’s. Tighten up!”",
        "71-75": "“Your Uplifting Primer looks far too unblemished to have been properly read, soldier.”",
        "76-80": "“The purity seal on your Lasgun has melted.”",
        "81-85": "“You appear amused, soldier. What infraction am I not aware of?”",
        "86-90": "“I’ve been informed that you have a special nickname for me, soldier?\"",
        "91-95": "“Your belly’s sticking out like an Ogryn.”",
        "96-100": "“Your spare power packs are not fully charged.”"
      }
    },
