    "Inquisition Personae - Mannerism": {
      "name": "Inquisition Personae - Mannerism",
      "description": "<p>Mannerism</p>",
      "results": {
        "1-1": "Moves stiffly, as though they are far older than they look.",
        "2-2": "Curses under their breath in mixed Low Gothic and slang.",
        "3-3": "Often performs a reading of the Emperor’s Tarot during conversations.",
        "4-4": "The fingers of their augmetic hand bend in unsettling directions.",
        "5-5": "Raises a single eyebrow while listening to anyone who speaks to them.",
        "6-6": "Hands constantly moving to  check the weapons about their  person.",
        "7-7": "Throws out questions on holy doctrine, testing other’s knowledge or ignorance.",
        "8-8": "Frequently inhales an unknown violet mixture from a rebreather.",
        "9-9": "A Servo-Skull hovers nearby, whispering a data feed into their ear.",
        "10-10": "They grimace and often touch their face, having recently used polymorphine to change their appearance."
      }
    },
    "Administratum Personae - Distinguishing Feature": {
      "name": "Administratum Personae - Distinguishing Feature",
      "description": "<p>Distinguishing Feature</p>",
      "results": {
        "1-1": "Forehead tattooed with a prayer against clerical error.",
        "2-2": "Been physically grafted into a cogitator unit.",
        "3-3": "No distinguishing features. They are utterly unremarkable.",
        "4-4": "A hidden augmetic that releases a strained whine when they move.",
        "5-5": "An antiquated respirator unit and vox-synthesiser, obscuring their lower face.",
        "6-6": "One arm has been replaced by a gilded Auto-Quill and inkwell.",
        "7-7": "Has several new cranial implants, the flesh of their skull still red and swollen.",
        "8-8": "Has several pairs of magnifier-glasses hung on chains around their neck.",
        "9-9": "Their face constantly cast in shadows from the harsh red glow of an augmetic eye.",
        "10-10": "Had their skull elongated and reconstructed, giving an almost equine appearance."
      }
    },
    "Adeptus Mechanicus Personae - Distinguishing Feature": {
      "name": "Adeptus Mechanicus Personae - Distinguishing Feature",
      "description": "<p>Distinguishing Feature</p>",
      "results": {
        "1-1": "A calculus logi unit makes up half their skull.",
        "2-2": "An augmetic heart, its parts proud and visible.",
        "3-3": "A pristine gold optical array, punctuated by a Ruby augmetic eye.",
        "4-4": "A ballistic mechadendrite that looms by their side menacingly.",
        "5-5": "A polished plasteel augmetic nose protrudes from their face.",
        "6-6": "A sheared off mechadendrite, with loose cables generating sparks.",
        "7-7": "A fully equipped medicae mechadendrite reaches over their shoulders.",
        "8-8": "A pair of extra long optical mechadendrites reach out from their spine.",
        "9-9": "A treaded track assembly has replaced their entire lower body.",
        "10-10": "A pair of backwards jointed spindly legs with strange hoof-like feet."
      }
    },
    "Astra Militarum Personae - Attitude": {
      "name": "Astra Militarum Personae - Attitude",
      "description": "<p>Attitude</p>",
      "results": {
        "1-1": "Serious, competent, expects the same of everyone.",
        "2-2": "Acts as if they are forever standing at attention.",
        "3-3": "Thousand yard stare, slow to respond, and indecisive.",
        "4-4": "Sighs and rolls their eyes at every request, clearly resigned to their lot in life.",
        "5-5": "Suspicious, double and triple-checks codes and paperwork, causing delays.",
        "6-6": "Will make any excuse to avoid hard work or pursue difficult requests.",
        "7-7": "Condescending and snobby with all non-military personnel.",
        "8-8": "Bombastic and intimidating like a drill-sergeant ordering a recruit.",
        "9-9": "Calm and cooperative, at peace with their role in the God-Emperor’s army.",
        "10-10": "A happy contraband smuggler, willing to speed up requests in exchange for favours."
      }
    },
    "Macharian Maledictions": {
      "name": "Macharian Maledictions",
      "description": "<p><span style=\"font-family:Arial,sans-serif\"><strong style=\"font-weight:normal\" id=\"docs-internal-guid-cc3e875a-7fff-b0b6-4e5e-80216888038b\">Macharian Maledictions</strong></span></p>",
      "results": {
        "1-5": "“Warp take you and your kin!”",
        "6-10": "“You’d sit an Ork’s mother on the Golden Throne!”",
        "11-15": "“You have all the grace of a drunken Grox!”",
        "16-20": "“You’ve a personality blander than grey rations!”",
        "21-25": "“You’d need a Navigator house to find your own backside!”",
        "26-30": "“May the Great Rift swallow you and yours!”",
        "31-35": "“You’ve got a skull as thick as an Ogryn’s!”",
        "36-40": "“You knock-kneed, Warp-twisted, Throne-humping basdack!”",
        "41-45": "“Are you less tok-damned use than shoes on a Skitarius?”",
        "46-50": "“Your mind is so open it went and dribbled out your ears!”",
        "51-55": "“If a daemon ate your soul it would starve!”",
        "56-60": "“An ocean of blood wouldn’t wash your sins!”",
        "61-65": "“A Commissar would have you licking boots in minutes!”",
        "66-70": "“You’re not even worth Terra’s due.”",
        "71-75": "“You’d lose a fist-fight with a ratling!”",
        "76-80": "“You’re about as great tokking company as a servitor at a dinner party!”",
        "81-85": "“I pity the fleas unlucky enough to choose you.”",
        "86-90": "“Get some sacred unguents into that head of yours!”",
        "91-95": "“Must’ve tithed your brain and left your body behind.”",
        "96-100": "“You sump-sucking Dreg-tick!”"
      }
    },
