    "Adeptus Ministorum Personae - Role": {
      "name": "Adeptus Ministorum Personae - Role",
      "description": "<p>Role</p>",
      "results": {
        "1-1": "Battle Sister",
        "2-2": "Chapel-Master",
        "3-3": "Confessor",
        "4-4": "Deacon",
        "5-5": "Missionary",
        "6-6": "Preacher",
        "7-7": "Redemptionist",
        "8-8": "Relic-Keeper",
